# Enforce correct line endings
*.sh        text eol=lf
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.psd1      text eol=crlf
*.rb        text eol=lf
*.pkr.hcl   text eol=lf
*.pkrvars.hcl text eol=lf
Vagrantfile text eol=lf
*.md        text eol=lf
*.xml       text eol=lf
*.conf      text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf

# Binary files
*.box       binary
*.iso       binary
*.ova       binary
*.vmdk      binary
*.png       binary
*.jpg       binary
*.gif       binary
